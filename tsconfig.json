{
  "files": [],
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "strict": true,
    "module": "esnext",
    "moduleResolution": "node",
    "target": "esnext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*"
  ]
}
